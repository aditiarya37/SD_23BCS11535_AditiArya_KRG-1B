    <mxGraphModel dx="2587" dy="1123" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="QYWDmb7zeFeyNkt5c-ff-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;Problem Statement: Design a Whatsapp system&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="620" x="-100" y="70" as="geometry" />
        </mxCell>
        <mxCell id="QYWDmb7zeFeyNkt5c-ff-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="1. User servive&lt;div&gt;2. Chat service&lt;/div&gt;&lt;div&gt;3. Group service&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="100" x="60" y="110" as="geometry" />
        </mxCell>
        <mxCell id="QYWDmb7zeFeyNkt5c-ff-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;ul&gt;&lt;li&gt;Optimize the chat service for handling millions of requests.&amp;nbsp;&lt;/li&gt;&lt;li&gt;Specify the type of connection used in the design.&amp;nbsp;&lt;/li&gt;&lt;li&gt;Determine how the designing will be done for LAST SEEN functionality.&lt;/li&gt;&lt;li&gt;Implement CDC Pipeline in the same architecture.&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="30" width="510" x="30" y="170" as="geometry" />
        </mxCell>
        <mxCell id="QYWDmb7zeFeyNkt5c-ff-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;Functional Requirements&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="210" x="30" y="250" as="geometry" />
        </mxCell>
        <mxCell id="QYWDmb7zeFeyNkt5c-ff-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;ol&gt;&lt;li&gt;User should be able to register and login.&lt;/li&gt;&lt;li&gt;User should be able to send and receive messages in real time.&lt;/li&gt;&lt;li&gt;User should be able to make groups and send messages in groups.&lt;/li&gt;&lt;li&gt;User should be able to send images/videos.&lt;/li&gt;&lt;li&gt;User should be able to see Last Seen/ Online status.&lt;/li&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="30" width="410" x="30" y="300" as="geometry" />
        </mxCell>
        <mxCell id="QYWDmb7zeFeyNkt5c-ff-8" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;Non-Functional Requirements&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="210" x="50" y="370" as="geometry" />
        </mxCell>
        <mxCell id="QYWDmb7zeFeyNkt5c-ff-9" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;ol&gt;&lt;li&gt;System should have low latency&lt;/li&gt;&lt;li&gt;System should be able to handle millions of users (highly scalable).&lt;/li&gt;&lt;li&gt;High availability and eventual consistency is required.&lt;/li&gt;&lt;li&gt;System should be reliable, no message should be lost.&lt;/li&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="30" width="410" x="30" y="420" as="geometry" />
        </mxCell>
        <mxCell id="QYWDmb7zeFeyNkt5c-ff-10" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;Core Entities&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="210" x="-10" y="470" as="geometry" />
        </mxCell>
        <mxCell id="QYWDmb7zeFeyNkt5c-ff-11" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;ol&gt;&lt;li&gt;User&lt;/li&gt;&lt;li&gt;Message&lt;/li&gt;&lt;li&gt;Group&lt;/li&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="30" width="410" x="30" y="510" as="geometry" />
        </mxCell>
        <mxCell id="QYWDmb7zeFeyNkt5c-ff-12" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;API Endpoints&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="210" x="-10" y="560" as="geometry" />
        </mxCell>
        <mxCell id="QYWDmb7zeFeyNkt5c-ff-13" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;ol&gt;&lt;li&gt;User Registration:&amp;nbsp; POST /user/register&lt;/li&gt;&lt;li&gt;User Login:&amp;nbsp; POST /user/login&lt;/li&gt;&lt;li&gt;Send Message via websocket: WS /messages/send&lt;/li&gt;&lt;li&gt;Get chats list (using pagination): GET /chat/{user_id}&lt;/li&gt;&lt;li&gt;Get messages for specific user: GET /messages/{user_id}/{receiver_id}&lt;/li&gt;&lt;li&gt;Create group: POST /groups/create&lt;/li&gt;&lt;li&gt;Send message in group: WS /messages/send&lt;/li&gt;&lt;li&gt;Get group chats (using pagination): GET /groups/{groud_id}&lt;/li&gt;&lt;li&gt;Add member in a group: POST /groups/{group_id}/add&lt;/li&gt;&lt;li&gt;Remove member: DELETE /groups/{group_id}/remove&amp;nbsp;&lt;/li&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="30" width="490" x="30" y="650" as="geometry" />
        </mxCell>
